Thumbs.db

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Node (if frontend is in a sibling directory and Docker build context is root)
node_modules/
frontend/

# Git
.git/
.gitignore

# Docs
README.md
*.md
