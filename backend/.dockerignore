# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment secrets — NEVER bake into image
.env
.env.*
!.env.example

# OAuth tokens — mount as secrets in Cloud Run
token.json
calendar_token.json

# Development tools
*.log
